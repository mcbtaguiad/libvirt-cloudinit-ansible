#cloud-config
users:
  - name: {{ vm_user }}
    gecos: {{ vm_user }}
    lock-passwd: true
    ssh_authorized_keys:
{% for key in ssh_public_key %}
      - "{{ key }}"
{% endfor %}
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    groups: sudo
    shell: /bin/bash

ssh_pwauth: false
disable_root: true

packages:
  - qemu-guest-agent

runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl start qemu-guest-agent
